#!/usr/bin/env sh

# Run unit tests only when pushing tags.
ZERO_SHA="0000000000000000000000000000000000000000"
SHOULD_RUN=0

if command -v pwsh >/dev/null 2>&1; then
  PS_CMD="pwsh"
elif command -v powershell >/dev/null 2>&1; then
  PS_CMD="powershell"
else
  echo "[pre-push] PowerShell not found. Push aborted."
  exit 1
fi

# stdin lines: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA
do
  case "$REMOTE_REF" in
    refs/tags/*)
      if [ "$LOCAL_SHA" != "$ZERO_SHA" ]; then
        SHOULD_RUN=1

        TAG_NAME="${REMOTE_REF#refs/tags/}"
        case "$TAG_NAME" in
          v*)
            echo "[pre-push] Validating tag/manifest alignment for $TAG_NAME..."
            "$PS_CMD" -NoProfile -ExecutionPolicy Bypass -File "./Tools/Validate-ReleaseTagManifest.ps1" -Tag "$TAG_NAME"
            STATUS=$?
            if [ $STATUS -ne 0 ]; then
              echo "[pre-push] Tag/manifest validation failed. Push aborted."
              exit $STATUS
            fi
            ;;
        esac
      fi
      ;;
  esac
done

if [ "$SHOULD_RUN" -ne 1 ]; then
  echo "[pre-push] No tag push detected. Skipping unit tests."
  exit 0
fi

echo "[pre-push] Tag push detected. Running unit tests..."
"$PS_CMD" -NoProfile -ExecutionPolicy Bypass -File "./Tools/Run-Tests.ps1"
STATUS=$?

if [ $STATUS -ne 0 ]; then
  echo "[pre-push] Unit tests failed. Push aborted."
  exit $STATUS
fi

echo "[pre-push] Unit tests passed. Proceeding with push."
exit 0
